default_platform(:ios)

platform :ios do
  desc "Build the app (no signing, for CI)"
  lane :build do
    xcodebuild(
      project: "GymClock.xcodeproj",
      scheme: "GymClock",
      configuration: "Debug",
      clean: true,
      build: true,
      destination: "generic/platform=iOS Simulator",
      xcargs: "CODE_SIGNING_ALLOWED=NO"
    )
  end

  desc "Run tests"
  lane :test do
    scan(
      project: "GymClock.xcodeproj",
      scheme: "GymClock",
      device: "iPhone 16",
      clean: true
    )
  end
end
